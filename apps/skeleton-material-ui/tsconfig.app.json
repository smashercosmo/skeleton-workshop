{
  "extends": "./tsconfig.paths.json",
  "compilerOptions": {
    "outDir": "./dist",
    "tsBuildInfoFile": "./dist/tsconfig.app.tsbuildinfo",
    "jsx": "react-jsx",
    "lib": ["es2022", "dom", "dom.iterable"],
    "types": ["vite/client"],
    "resolveJsonModule": true,
  },
  "exclude": ["./dist", ".storybook/main.ts", "./**/*.stories.*", "./vite.config.ts", ".storybook/preview.tsx"],
  "include": [".", "./src/**/*.json"]
}
