{
  "extends": "./tsconfig.paths.json",
  "compilerOptions": {
    "outDir": "./dist",
    "tsBuildInfoFile": "./dist/tsconfig.storybook.tsbuildinfo",
    "jsx": "react-jsx",
    "types": ["vite/client"],

    // https://github.com/storybookjs/storybook/issues/33770
    "composite": false,
    "declaration": false,
    "emitDeclarationOnly": false,
    "declarationMap": false,
    "noEmit": true
  },
  "include": ["./**/*.stories.*", ".storybook/preview.tsx"],
  "references": [
    {
      "path": "./tsconfig.app.json"
    }
  ]
}
